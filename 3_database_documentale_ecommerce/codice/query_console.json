# full-search
GET /catalogo_prodotti/_search
{
  "query": {
    "match": {
      "descrizione": "batteria"
    }
  }
}

#filter
GET /catalogo_prodotti/_search
{
  "query": {
    "bool": {
      "must": {
        "match": { "categoria": "Elettronica" }
      },
      "filter": {
        "range": {
          "prezzo": { "lt": 200.00 }
        }
      }
    }
  }
}
